generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProcurementType {
  PURCHASE
  MANUFACTURING
}
enum ProductCategory {
  RAW_MATERIAL
  FINISHED_GOOD
  SERVICE
}
enum StockDirection {
  IN
  OUT
}
enum StockSource {
  MANUAL_ADJUSTMENT
  SALES_DELIVERY
  PURCHASE_RECEIPT
  MO_CONSUMPTION
  MO_PRODUCTION
}
enum SalesStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_DELIVERED
  FULLY_DELIVERED
  CANCELLED
}
enum PurchaseStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}
enum ManufacturingStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  CONFIRM
  CANCEL
  DELIVER
  RECEIVE
  START
  COMPLETE
  LOGIN
  PERMISSION_CHANGE
  INVENTORY_CHANGE
}

enum ProcurementAlertType {
  LOW_STOCK
  PREDICTED_STOCKOUT
  HIGH_DEMAND
  MATERIAL_SHORTAGE
}

enum RecommendationStatus {
  PENDING
  APPROVED
  REJECTED
  SUPERSEDED
}

enum AccessLevel {
  ADMIN
  VIEW
}
model User {
  id String @id @default(uuid())
  loginId String @unique
  email String @unique
  passwordHash String
  name String
  address String?
  mobile String?
  position String?
  active Boolean @default(true)
  tokenVersion Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles UserRole[]
  audits AuditLog[]
  notifications Notification[]
  passwordResetTokens PasswordResetToken[]
  @@map("users")
}
model PasswordResetToken {
  id String @id @default(uuid())
  userId String
  tokenHash String @unique
  expiresAt DateTime
  usedAt DateTime?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model Role {
  id String @id @default(uuid())
  name String @unique
  description String?
  permissions RolePermission[]
  users UserRole[]
  @@map("roles")
}
model Permission {
  id String @id @default(uuid())
  module String @unique
  description String?
  roles RolePermission[]
  @@map("permissions")
}
model UserRole {
  userId String
  roleId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
  @@map("user_roles")
}
model RolePermission {
  roleId String
  permissionId String
  accessLevel AccessLevel
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
  @@map("role_permissions")
}
model Customer {
  id String @id @default(uuid())
  reference String @unique
  name String
  address String?
  contact String?
  createdAt DateTime @default(now())
  salesOrders SalesOrder[]
  @@map("customers")
}
model Vendor {
  id String @id @default(uuid())
  reference String @unique
  name String
  address String?
  contact String?
  leadTimeDays Int @default(0)
  createdAt DateTime @default(now())
  products Product[]
  purchaseOrders PurchaseOrder[]
  procurementRecommendations ProcurementRecommendation[]
  @@map("vendors")
}
model Product {
  id String @id @default(uuid())
  reference String @unique
  name String @unique
  category ProductCategory @default(RAW_MATERIAL)
  salesPrice Decimal @db.Decimal(14, 2)
  costPrice Decimal @db.Decimal(14, 2)
  onHandQty Decimal @default(0) @db.Decimal(14, 3)
  reorderPoint Decimal @default(0) @db.Decimal(14, 3)
  safetyStock Decimal @default(0) @db.Decimal(14, 3)
  procureOnDemand Boolean @default(false)
  procurementType ProcurementType?
  defaultVendorId String?
  defaultBomId String? @unique
  active Boolean @default(true)
  vendor Vendor? @relation(fields: [defaultVendorId], references: [id], onDelete: Restrict)
  defaultBom Bom? @relation("DefaultBom", fields: [defaultBomId], references: [id], onDelete: Restrict)
  boms Bom[] @relation("FinishedProduct")
  movements StockMovement[]
  reservations InventoryReservation[]
  salesItems SalesOrderItem[]
  purchaseItems PurchaseOrderItem[]
  moFinished ManufacturingOrder[] @relation("FinishedGood")
  manufacturingItems ManufacturingOrderItem[]
  bomComponents BomItem[]
  procurementAlerts ProcurementAlert[]
  procurementRecommendations ProcurementRecommendation[]
  demandHistory DemandHistory[]
  @@index([name])
  @@map("products")
}
model Bom {
  id String @id @default(uuid())
  reference String @unique
  finishedProductId String
  referenceQty Decimal @db.Decimal(14, 3)
  active Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  finishedProduct Product @relation("FinishedProduct", fields: [finishedProductId], references: [id], onDelete: Restrict)
  items BomItem[]
  operations BomOperation[]
  defaultForProduct Product? @relation("DefaultBom")
  manufacturingOrders ManufacturingOrder[]
  @@map("bom")
}
model BomItem {
  id String @id @default(uuid())
  bomId String
  productId String
  quantity Decimal @db.Decimal(14, 3)
  bom Bom @relation(fields: [bomId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  @@unique([bomId, productId])
  @@map("bom_items")
}
model BomOperation {
  id String @id @default(uuid())
  bomId String
  name String
  workCenter String?
  expectedMinutes Decimal @db.Decimal(12, 2)
  bom Bom @relation(fields: [bomId], references: [id], onDelete: Cascade)
  @@map("bom_operations")
}
model SalesOrder {
  id String @id @default(uuid())
  reference String @unique
  customerId String
  customerAddress String?
  salesPersonId String?
  status SalesStatus @default(DRAFT)
  availabilityFlag Boolean @default(false)
  expectedDeliveryDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items SalesOrderItem[]
  reservations InventoryReservation[]
  triggerPurchaseOrders PurchaseOrder[] @relation("TriggerSOPO")
  triggerManufacturingOrders ManufacturingOrder[] @relation("TriggerSOMO")
  @@index([status, createdAt])
  @@map("sales_orders")
}
model SalesOrderItem {
  id String @id @default(uuid())
  salesOrderId String
  productId String
  orderedQty Decimal @db.Decimal(14, 3)
  deliveredQty Decimal @default(0) @db.Decimal(14, 3)
  salesPrice Decimal @db.Decimal(14, 2)
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  @@map("sales_order_items")
}
model PurchaseOrder {
  id String @id @default(uuid())
  reference String @unique
  vendorId String
  vendorAddress String?
  responsiblePersonId String?
  status PurchaseStatus @default(DRAFT)
  autoCreated Boolean @default(false)
  triggerSourceSoId String?
  expectedReceiptDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  triggerSourceSo SalesOrder? @relation("TriggerSOPO", fields: [triggerSourceSoId], references: [id], onDelete: SetNull)
  items PurchaseOrderItem[]
  @@index([status, createdAt])
  @@map("purchase_orders")
}
model PurchaseOrderItem {
  id String @id @default(uuid())
  purchaseOrderId String
  productId String
  orderedQty Decimal @db.Decimal(14, 3)
  receivedQty Decimal @default(0) @db.Decimal(14, 3)
  costPrice Decimal @db.Decimal(14, 2)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  @@map("purchase_order_items")
}
model ManufacturingOrder {
  id String @id @default(uuid())
  reference String @unique
  finishedProductId String
  bomId String
  quantity Decimal @db.Decimal(14, 3)
  status ManufacturingStatus @default(DRAFT)
  autoCreated Boolean @default(false)
  triggerSourceSoId String?
  plannedCompletionDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  finishedProduct Product @relation("FinishedGood", fields: [finishedProductId], references: [id], onDelete: Restrict)
  bom Bom @relation(fields: [bomId], references: [id], onDelete: Restrict)
  triggerSourceSo SalesOrder? @relation("TriggerSOMO", fields: [triggerSourceSoId], references: [id], onDelete: SetNull)
  items ManufacturingOrderItem[]
  workOrders WorkOrder[]
  reservations InventoryReservation[]
  @@index([status, createdAt])
  @@map("manufacturing_orders")
}
model ManufacturingOrderItem {
  id String @id @default(uuid())
  manufacturingOrderId String
  productId String
  requiredQty Decimal @db.Decimal(14, 3)
  consumedQty Decimal @default(0) @db.Decimal(14, 3)
  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  @@map("manufacturing_order_items")
}
model WorkOrder {
  id String @id @default(uuid())
  manufacturingOrderId String
  name String
  workCenter String?
  expectedMinutes Decimal @db.Decimal(12, 2)
  actualMinutes Decimal? @db.Decimal(12, 2)
  operatorId String?
  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  @@map("work_orders")
}
model InventoryReservation {
  id String @id @default(uuid())
  productId String
  salesOrderId String?
  manufacturingOrderId String?
  quantity Decimal @db.Decimal(14, 3)
  active Boolean @default(true)
  createdAt DateTime @default(now())
  releasedAt DateTime?
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  salesOrder SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  manufacturingOrder ManufacturingOrder? @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  @@index([productId, active])
  @@index([salesOrderId, active])
  @@index([manufacturingOrderId, active])
  @@map("inventory_reservations")
}
model StockMovement {
  id String @id @default(uuid())
  productId String
  direction StockDirection
  quantity Decimal @db.Decimal(14, 3)
  signedQty Decimal @db.Decimal(14, 3)
  source StockSource
  referenceType String
  referenceId String
  actorId String?
  createdAt DateTime @default(now())
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  @@index([productId, createdAt])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}
model AuditLog {
  id String @id @default(uuid())
  actorId String?
  module String
  recordType String
  recordId String
  action AuditAction
  fieldName String?
  oldValue String?
  newValue String?
  createdAt DateTime @default(now())
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  @@index([recordType, recordId])
  @@map("audit_logs")
}
model Notification {
  id String @id @default(uuid())
  userId String?
  type String
  message String
  readAt DateTime?
  createdAt DateTime @default(now())
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, readAt])
  @@map("notifications")
}

model ProcurementAlert {
  id String @id @default(uuid())
  productId String
  type ProcurementAlertType
  message String
  resolved Boolean @default(false)
  createdAt DateTime @default(now())
  resolvedAt DateTime?
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId, resolved])
  @@map("procurement_alerts")
}

model ProcurementRecommendation {
  id String @id @default(uuid())
  productId String
  vendorId String?
  recommendedQty Decimal @db.Decimal(14, 3)
  priority String
  confidenceScore Decimal @db.Decimal(5, 2)
  explanation String
  status RecommendationStatus @default(PENDING)
  createdAt DateTime @default(now())
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  @@index([productId, status])
  @@map("procurement_recommendations")
}

model DemandHistory {
  id String @id @default(uuid())
  productId String
  date DateTime
  totalQuantity Decimal @db.Decimal(14, 3)
  createdAt DateTime @default(now())
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@unique([productId, date])
  @@map("demand_history")
}
