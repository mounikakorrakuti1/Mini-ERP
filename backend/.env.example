# Database connection string
DATABASE_URL="postgresql://postgres:postgres@db:5432/erp_db?schema=public"

# Node environment (development, test, production)
NODE_ENV="production"

# Port for the backend API to listen on
PORT=3000

# Secret key for signing JWT tokens
JWT_SECRET="YOUR_SUPER_SECRET_KEY_HERE_MIN_32_CHARS"

# (Optional) Log level
LOG_LEVEL="info"
