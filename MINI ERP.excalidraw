      "seed": 70722453,
      "version": 664,
      "versionNonce": 1488271647,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780913099776,
      "link": null,
      "locked": false,
      "text": "For Sign up Page,\nCeate a user database into the system on signup\nCheck creds as follows\n1. login ID should be unique and must be in between 6-12 charachters.\n2. Email Id should not be a duplicate in database\n3.Password must me unique and must contain a small case, a large case and \na special character and length should be in more then 8 charachters. ",
      "fontSize": 7.5428571428571365,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For Sign up Page,\nCeate a user database into the system on signup\nCheck creds as follows\n1. login ID should be unique and must be in between 6-12 charachters.\n2. Email Id should not be a duplicate in database\n3.Password must me unique and must contain a small case, a large case and \na special character and length should be in more then 8 charachters. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
