    {
      "id": "BrdZKof8erK5poTmnO9IU",
      "type": "text",
      "x": -291.61472109839997,
      "y": 107.50000000000011,
      "width": 278.93109130859375,
      "height": 65.99999999999994,
      "angle": 0,
      "strokeColor": "#1e1e1e",
