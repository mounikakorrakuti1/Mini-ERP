    {
      "id": "Hxhj3XMi3P575h_Z3mkPM",
      "type": "text",
      "x": 1768.0803701874083,
      "y": 240.8504106083676,
      "width": 556.7398681640625,
      "height": 88.18978886416971,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bM9",
      "roundness": null,
      "seed": 1144903763,
      "version": 1179,
      "versionNonce": 293963958,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779779358063,
      "link": null,
      "locked": false,
      "text": "-Filter respective orders when user clicks on any of the state button, \nhighlight the clicked button and add filter on serach according to the button click.\n\n-Late Filter shows orders whose start date has already passed and are still in confirmed state.\n\n-Delivered Filter is for sales order with all products quantity is fully delivered (same in Purchase for fully recieved)\n\n-Partially Delivered is for sales order with certain product quantity is not fully delivered (same in Purchase for partially recieved)",
      "fontSize": 8.818978886416971,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-Filter respective orders when user clicks on any of the state button, \nhighlight the clicked button and add filter on serach according to the button click.\n\n-Late Filter shows orders whose start date has already passed and are still in confirmed state.\n\n-Delivered Filter is for sales order with all products quantity is fully delivered (same in Purchase for fully recieved)\n\n-Partially Delivered is for sales order with certain product quantity is not fully delivered (same in Purchase for partially recieved)",
      "autoResize": true,
      "lineHeight": 1.25
    },
